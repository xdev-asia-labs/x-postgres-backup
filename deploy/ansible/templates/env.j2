# x-postgres-backup environment configuration
APP_NAME={{ app_name }}
APP_HOST=0.0.0.0
APP_PORT={{ app_port }}
APP_LOG_LEVEL={{ app_log_level }}

PATRONI_NODES={{ patroni_nodes | default('10.10.10.11:8008,10.10.10.12:8008,10.10.10.13:8008') }}
PATRONI_AUTH_ENABLED={{ patroni_auth_enabled | default('false') }}
PATRONI_AUTH_USERNAME={{ patroni_auth_username | default('') }}
PATRONI_AUTH_PASSWORD={{ patroni_auth_password | default('') }}

PG_PORT={{ pg_port | default('5432') }}
PG_USER={{ pg_user | default('postgres') }}
PG_PASSWORD={{ pg_password | default('') }}
PG_BIN_DIR={{ pg_bin_dir | default('/usr/lib/postgresql/18/bin') }}
PG_REPLICATION_USER={{ pg_replication_user | default('replicator') }}
PG_REPLICATION_PASSWORD={{ pg_replication_password | default('') }}

BACKUP_DIR={{ backup_dir }}
BACKUP_RETENTION_DAYS={{ backup_retention_days | default('7') }}
BACKUP_RETENTION_COPIES={{ backup_retention_copies | default('7') }}

SCHEDULE_BASEBACKUP={{ schedule_basebackup | default('0 2 * * *') }}
SCHEDULE_PGDUMP={{ schedule_pgdump | default('0 3 * * *') }}
SCHEDULE_VERIFY={{ schedule_verify | default('0 4 * * *') }}
SCHEDULE_CLEANUP={{ schedule_cleanup | default('0 6 * * *') }}

DATABASE_URL=sqlite:///{{ app_dir }}/data/backup_manager.db
