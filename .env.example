# x-postgres-backup Configuration
# Copy to .env and update with your values

# =============================================================================
# APP SETTINGS
# =============================================================================
APP_NAME=x-postgres-backup
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=info
APP_SECRET_KEY=change-me-to-a-random-secret-key

# =============================================================================
# CLUSTER CONNECTION
# =============================================================================
# Patroni REST API endpoints (comma-separated)
PATRONI_NODES=10.10.10.11:8008,10.10.10.12:8008,10.10.10.13:8008
PATRONI_AUTH_ENABLED=false
PATRONI_AUTH_USERNAME=patroni_admin
PATRONI_AUTH_PASSWORD=

# PostgreSQL connection (used for pg_dump/restore)
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=
PG_BIN_DIR=/usr/lib/postgresql/18/bin

# Replication user (for pg_basebackup)
PG_REPLICATION_USER=replicator
PG_REPLICATION_PASSWORD=

# =============================================================================
# BACKUP SETTINGS
# =============================================================================
BACKUP_DIR=/var/backups/postgresql
BACKUP_RETENTION_DAYS=7
BACKUP_RETENTION_COPIES=7
BACKUP_COMPRESSION=gzip

# =============================================================================
# SCHEDULE (cron expressions: minute hour day month day_of_week)
# =============================================================================
SCHEDULE_BASEBACKUP=0 2 * * *
SCHEDULE_PGDUMP=0 3 * * *
SCHEDULE_VERIFY=0 4 * * *
SCHEDULE_CLEANUP=0 6 * * *

# =============================================================================
# DATABASE (local state - SQLite)
# =============================================================================
DATABASE_URL=sqlite:///data/backup_manager.db
