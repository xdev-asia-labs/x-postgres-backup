# x-postgres-backup Configuration
# Copy to .env and update with your values

# =============================================================================
# APP SETTINGS
# =============================================================================
APP_NAME=x-postgres-backup
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=info
APP_SECRET_KEY=change-me-to-a-random-secret-key

# =============================================================================
# CLUSTER CONNECTION
# =============================================================================
# Patroni REST API endpoints (comma-separated)
PATRONI_NODES=10.10.10.11:8008,10.10.10.12:8008,10.10.10.13:8008
PATRONI_AUTH_ENABLED=false
PATRONI_AUTH_USERNAME=patroni_admin
PATRONI_AUTH_PASSWORD=

# PostgreSQL connection (used for pg_dump/restore)
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=

# PostgreSQL version (16, 17, 18) — auto-resolves PG_BIN_DIR
PG_VERSION=18
# Override only if your binaries are in a non-standard path:
# PG_BIN_DIR=/usr/lib/postgresql/18/bin

# Replication user (for pg_basebackup)
PG_REPLICATION_USER=replicator
PG_REPLICATION_PASSWORD=

# =============================================================================
# BACKUP SETTINGS
# =============================================================================
BACKUP_DIR=/var/backups/postgresql
BACKUP_RETENTION_DAYS=7
BACKUP_RETENTION_COPIES=7
BACKUP_COMPRESSION=gzip

# =============================================================================
# SCHEDULE (cron expressions: minute hour day month day_of_week)
# =============================================================================
SCHEDULE_BASEBACKUP=0 2 * * *
SCHEDULE_PGDUMP=0 3 * * *
SCHEDULE_VERIFY=0 4 * * *
SCHEDULE_CLEANUP=0 6 * * *

# =============================================================================
# DATABASE (local state - SQLite)
# =============================================================================
DATABASE_URL=sqlite:///data/backup_manager.db

# =============================================================================
# NOTIFICATIONS
# =============================================================================
# Telegram Notifications
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Email Notifications
EMAIL_ENABLED=false
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=your_email@gmail.com
EMAIL_SMTP_PASSWORD=your_app_password
EMAIL_FROM=your_email@gmail.com
EMAIL_TO=admin1@example.com,admin2@example.com
EMAIL_USE_TLS=true

# =============================================================================
# AUTHENTICATION & AUTHORIZATION
# =============================================================================
# Enable/disable authentication (set to false to disable login requirement)
AUTH_ENABLED=true

# JWT Settings
JWT_SECRET_KEY=change-me-to-a-secure-random-string-for-jwt
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Session Settings
SESSION_SECRET_KEY=change-me-to-a-secure-random-string-for-session
SESSION_COOKIE_NAME=xpb_session
SESSION_MAX_AGE=86400

# Default Admin Account (created on first startup)
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=admin123

# User Management
ALLOW_REGISTRATION=true
REQUIRE_EMAIL_VERIFICATION=false

# =============================================================================
# SSO - GOOGLE OAUTH2
# =============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# =============================================================================
# SSO - MICROSOFT OAUTH2
# =============================================================================
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:8000/auth/microsoft/callback
